{
  // Output filename and BoardLoader data-variable name:
  //   boardName "Ccode" -> designer/boards/ccode_Ccode/ccode_Ccode.json -> const ccode_CcodeData = {...}
  "boardName": "Ccode",

  // Fallback human-readable name shown in the designer UI.  No boards.txt
  // exists for this family, so this is also the final displayed name.
  "displayName": "Minimal C code",

  // Parser dialect that interprets this variant's pins_arduino.h.
  // "ccode" is a no-pin target for plain C code generation (no Arduino
  // core, no GPIOs) — buildCcodeBoard() ignores pins_arduino.h entirely
  // and always emits an empty pins[] array.
  "family": "ccode",

  // Default serial baud rate offered to the user on connect.  Required
  // non-null even though this target has no pins — the device still
  // talks pfod over a plain serial byte stream.
  "defaultBaud": 9600,

  // No baud-picker options offered for this target yet.
  "supportedBauds": [],

  // No GPIO concept applies — not used by buildCcodeBoard().
  "inputOnlyGpios": [],

  // This target only talks pfod over Serial.
  "connections": ["serial"],

  // No pins, so no pin notes.
  "pinNotes": {},

  // No GPIO concept applies — not used by buildCcodeBoard().
  "chipGpios": {},

  // No PWM, DAC or ADC support — no pins to carry them.
  "pwm": {},
  "dac": {},
  "adc": {}
}
