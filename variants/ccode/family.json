{
  // Human-readable name shown for this family in the Designer's target
  // picker.  Read generically by build_boards.js (nearest-ancestor
  // search, same pattern as board.json/boards.txt) — no family names
  // are hardcoded in the build scripts.
  "familyDisplayName": "Minimal C Code",

  // Lower sortOrder values appear earlier in the Designer's family
  // picker.  Families that omit this field default to 100 (see
  // DEFAULT_FAMILY_SORT_ORDER in build_boards.js).  9999 keeps this
  // target below every real board family regardless of what sortOrders
  // they are given.
  "sortOrder": 9999
}
