    "21": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "22": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "23": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
