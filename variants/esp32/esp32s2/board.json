{
  // Output filename and BoardLoader data-variable name:
  //   boardName "ESP32S2" -> designer/boards/ESP32S2/ESP32S2.json -> const ESP32S2Data = {...}
  "boardName": "ESP32S2",

  // Fallback human-readable name shown in the designer UI.  Overridden
  // by the matching `<id>.name=` entry in a sibling-or-ancestor
  // boards.txt when one is present (matched via `<id>.build.variant=`
  // against this variant's directory name).
  "displayName": "ESP32-S2 Dev Module",

  // Parser dialect that interprets this variant's pins_arduino.h.
  // Supported values: "avr", "esp32".
  "family": "esp32",

  // Default serial baud rate offered to the user on connect.
  "defaultBaud": 115200,

  // Baud rates the designer's baud-picker offers for this board, in the
  // order they appear in the UI.
  "supportedBauds": [
    9600, 19200, 38400, 57600, 115200, 230400, 460800, 921600
  ],

  // Default PWM output range for analogWrite() (LEDC, 8-bit default).
  "pwm": { "min": 0, "max": 255, "method": "analogWrite" },

  // DAC output: ESP32-S2 has two 8-bit DAC channels on GPIO 17 and GPIO 18.
  // dacWrite(pin, value): value 0–255 maps to 0.0–3.3 V output.
  "dac": { "min": 0, "max": 255, "minVolts": "0.0", "maxVolts": "3.3", "method": "dacWrite" },

  // ADC: ESP32-S2 has a 12-bit ADC (0–4095) via analogRead().  Default reference
  // is the internal 3.3 V supply.  Attenuation settable via analogSetAttenuation()
  // for 0–3.3 V range; without attenuation input range is ~0–1.1 V.
  "adc": { "bits": 12, "max": 4095, "defaultRefVolts": "3.3" },

  // GPIO numbers that are input-only (no internal pull-up driver, no
  // output driver).  Used by the ESP32 parser to drop digital_output and
  // pwm_output capabilities from those pins.  Leave [] on boards where
  // every pin is bidirectional (e.g. all AVR variants).
  // ESP32-S2: GPIO46 is the only input-only pin on the chip.
  "inputOnlyGpios": [46],

  // Transports this board can talk pfod over.  Values are the lowercase
  // machine identifiers from pfodCommon.html's protocol radios.  ESP32
  // family supports Serial via UART, BLE via Bluetooth LE, TCP via the
  // WiFi stack, and HTTP via the WiFi stack + a small server library.
  "connections": ["serial", "ble", "tcp", "http"],

  // Boot-time / power-up warnings for specific GPIO numbers.
  // Reference: ESP32-S2 Technical Reference Manual — Strapping Pins.
  "pinNotes": {
    "0":  "Must be HIGH for normal boot",
    "45": "Must be LOW or floating on reboot",
    "46": "Must be LOW or floating on reboot"
  },

  // User-accessible GPIO numbers on the ESP32-S2 chip.  GPIOs 26-32
  // (flash/PSRAM) and GPIOs 19-20 (USB) are excluded.  GPIO 46 is
  // input-only (no output driver).  GPIOs 22-25 do not exist in this
  // chip's silicon.
  // Source: Espressif ESP-IDF documentation (docs.espressif.com).
  "chipGpios": {
    "0":  { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "1":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "2":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "3":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "4":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "5":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "6":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "7":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "8":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "9":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "10": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "11": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "12": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "13": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "14": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "15": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "16": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "17": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output", "dac_output"] },
    "18": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output", "dac_output"] },
    "21": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "33": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "34": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "35": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "36": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "37": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "38": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "39": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "40": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "41": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "42": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "43": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "44": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "45": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "46": { "capabilities": ["digital_input"] }
  }
}
