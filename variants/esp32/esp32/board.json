{
  // Output filename and BoardLoader data-variable name:
  //   boardName "ESP32" -> designer/boards/ESP32/ESP32.json -> const ESP32Data = {...}
  "boardName": "ESP32",

  // Fallback human-readable name shown in the designer UI.  Overridden
  // by the matching `<id>.name=` entry in a sibling-or-ancestor
  // boards.txt when one is present (matched via `<id>.build.variant=`
  // against this variant's directory name).
  "displayName": "ESP32 Dev Module",

  // Parser dialect that interprets this variant's pins_arduino.h.
  // Supported values: "avr", "esp32".
  "family": "esp32",

  // Default serial baud rate offered to the user on connect.
  "defaultBaud": 115200,

  // Baud rates the designer's baud-picker offers for this board, in the
  // order they appear in the UI.
  "supportedBauds": [
    9600, 19200, 38400, 57600, 115200, 230400, 460800, 921600
  ],

  // Default PWM output range for analogWrite() (LEDC, 8-bit default).
  "pwm": { "min": 0, "max": 255, "method": "analogWrite" },

  // DAC output: ESP32 has two 8-bit DAC channels on GPIO 25 and GPIO 26.
  // dacWrite(pin, value): value 0–255 maps to 0.0–3.3 V output.
  "dac": { "min": 0, "max": 255, "minVolts": "0.0", "maxVolts": "3.3", "method": "dacWrite" },

  // ADC: ESP32 has a 12-bit ADC (0–4095) via analogRead().  Default reference
  // is the internal 3.3 V supply.  Attenuation can be set via analogSetAttenuation()
  // for full 0–3.3 V range; without attenuation input range is ~0–1.1 V.
  "adc": { "bits": 12, "max": 4095, "defaultRefVolts": "3.3" },

  // GPIO numbers that are input-only (no internal pull-up driver, no
  // output driver).  Used by the ESP32 parser to drop digital_output and
  // pwm_output capabilities from those pins.  Leave [] on boards where
  // every pin is bidirectional (e.g. all AVR variants).
  "inputOnlyGpios": [34, 35, 36, 37, 38, 39],

  // Transports this board can talk pfod over.  Values are the lowercase
  // machine identifiers from pfodCommon.html's protocol radios.  ESP32
  // family supports Serial via UART, BLE via Bluetooth LE, TCP via the
  // WiFi stack, and HTTP via the WiFi stack + a small server library.
  "connections": ["serial", "ble", "tcp", "http"],

  // Boot-time / power-up warnings for specific GPIO numbers.
  // Keys are GPIO numbers as strings; values are plain text shown
  // under the pin label in the pin picker (use \n for line breaks).
  // Reference: ESP32 Technical Reference Manual — Strapping Pins section.
  "pinNotes": {
    "0":  "Must be HIGH or floating on reboot",
    "2":  "Must be LOW or floating at boot",
    "5":  "Must be HIGH or floating on reboot",
    "12": "Must be LOW or floating on reboot",
    "15": "Must be HIGH or floating on reboot"
  },

  // User-accessible GPIO numbers on the ESP32 chip.  GPIOs 6-11 (flash)
  // and 16-17 (PSRAM) are excluded — not user-accessible on modules with
  // integrated flash/PSRAM.  GPIOs 34-39 are input-only (no output driver).
  // GPIOs 20, 24, 28-31 do not exist in this chip's silicon.
  // Source: Espressif ESP-IDF documentation (docs.espressif.com).
  "chipGpios": {
    "0":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "1":  { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "2":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "3":  { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "4":  { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "5":  { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "12": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "13": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "14": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "15": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "18": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "19": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "21": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "22": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "23": { "capabilities": ["digital_input", "digital_output", "pwm_output"] },
    "25": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output", "dac_output"] },
    "26": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output", "dac_output"] },
    "27": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "32": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "33": { "capabilities": ["analog_input", "digital_input", "digital_output", "pwm_output"] },
    "34": { "capabilities": ["analog_input", "digital_input"] },
    "35": { "capabilities": ["analog_input", "digital_input"] },
    "36": { "capabilities": ["analog_input", "digital_input"] },
    "37": { "capabilities": ["analog_input", "digital_input"] },
    "38": { "capabilities": ["analog_input", "digital_input"] },
    "39": { "capabilities": ["analog_input", "digital_input"] }
  }
}
