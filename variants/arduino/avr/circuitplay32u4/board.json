{
  // boardName / displayName are overridden by boards.txt entry:
  //   circuitplay32u4cat.name=Adafruit Circuit Playground
  "boardName": "circuitplay32u4",
  "displayName": "Adafruit Circuit Playground Classic",

  // ATmega32U4 at 8 MHz / 3.3 V — same header layout as the Leonardo.
  // Serial1 is the hardware USART on the alligator-clip pads (D0=RX, D1=TX).
  // Serial is USB-CDC and is not a suitable pfod transport.
  "family": "avr",

  "defaultBaud": 115200,
  "supportedBauds": [
    300, 600, 1200, 2400, 4800, 9600, 14400, 19200,
    28800, 38400, 57600, 115200
  ],

  "pwm": { "min": 0, "max": 255, "method": "analogWrite" },
  "dac": {},
  // ADC: ATmega32U4 has a 10-bit ADC (0–1023).  Default reference is
  // AVCC = 5 V.  Internal 2.56 V reference available via analogReference(INTERNAL).
  "adc": { "bits": 10, "max": 1023, "defaultRefVolts": "5.0" },
  "inputOnlyGpios": [],

  // Hardware serial via the D0/D1 alligator-clip pads (Serial1 in sketch).
  "connections": ["serial"],

  "pinNotes": {},
  "chipGpios": {}
}
