{
  // Fallback boardName / displayName — overridden by boards.txt for every
  // board that declares `build.variant=leonardo` (leonardo, leonardoeth,
  // esplora, LilyPadUSB).  Also inherited via the #include chain by the
  // `yun` and `micro` variant directories.
  "boardName": "leonardo",
  "displayName": "Arduino Leonardo",

  // Parser dialect — 32U4 pins_arduino.h uses the same AVR #define layout.
  "family": "avr",

  // Default serial baud rate for pfod connections (via Serial1, the
  // hardware USART on D0/D1).
  "defaultBaud": 115200,

  "supportedBauds": [
    300, 600, 1200, 2400, 4800, 9600, 14400, 19200,
    28800, 38400, 57600, 115200
  ],

  // 8-bit PWM via analogWrite() — same as all AVR boards.
  "pwm": { "min": 0, "max": 255, "method": "analogWrite" },

  // ATmega32U4 has no hardware DAC.
  "dac": {},

  // ADC: ATmega32U4 has a 10-bit ADC (0–1023).  Default reference is
  // AVCC = 5 V.  Internal 2.56 V reference available via analogReference(INTERNAL).
  "adc": { "bits": 10, "max": 1023, "defaultRefVolts": "5.0" },

  // All AVR pins are bidirectional.
  "inputOnlyGpios": [],

  // pfod connections for 32U4 boards: hardware serial only (D0=RX1, D1=TX1).
  // Serial is USB-CDC and is not suitable as a pfod transport.
  "connections": ["serial"],

  // No boot-time pin restrictions on AVR boards.
  "pinNotes": {},

  // No chip GPIO concept on AVR boards.
  "chipGpios": {}
}
