{
  // Output filename and BoardLoader data-variable name:
  //   boardName "Uno" -> designer/boards/Uno/Uno.json -> const UnoData = {...}
  "boardName": "Uno",

  // Fallback human-readable name shown in the designer UI.  Overridden
  // by the matching `<id>.name=` entry in a sibling-or-ancestor
  // boards.txt when one is present (matched via `<id>.build.variant=`
  // against this variant's directory name).
  "displayName": "Arduino Uno",

  // Parser dialect that interprets this variant's pins_arduino.h.
  // Supported values: "avr", "esp32".
  "family": "avr",

  // Default serial baud rate offered to the user on connect.
  "defaultBaud": 115200,

  // Baud rates the designer's baud-picker offers for this board, in the
  // order they appear in the UI.
  "supportedBauds": [
    300, 600, 1200, 2400, 4800, 9600, 14400, 19200,
    28800, 38400, 57600, 115200
  ],

  // Default PWM output range for analogWrite().  AVR is 8-bit (0–255).
  "pwm": { "min": 0, "max": 255, "method": "analogWrite" },

  // DAC output: AVR has no hardware DAC.
  "dac": {},

  // ADC: ATmega328P has a 10-bit ADC (0–1023).  Default reference is
  // AVCC = 5 V on 5 V boards.  Internal 1.1 V reference also available
  // via analogReference(INTERNAL).
  "adc": { "bits": 10, "max": 1023, "defaultRefVolts": "5.0" },

  // GPIO numbers that are input-only (no internal pull-up driver, no
  // output driver).  Used by the ESP32 parser to drop digital_output and
  // pwm_output capabilities from those pins.  Leave [] on boards where
  // every pin is bidirectional (e.g. all AVR variants).
  "inputOnlyGpios": [],

  // Transports this board can talk pfod over.  Values are the lowercase
  // machine identifiers from pfodCommon.html's protocol radios.  AVR
  // boards typically only ship Serial — no on-board radio.
  "connections": ["serial"],

  // No boot-time pin restrictions on AVR boards.
  "pinNotes": {},

  // No chip GPIO concept on AVR boards (pins are addressed by digital pin
  // number, not GPIO number).
  "chipGpios": {}
}
