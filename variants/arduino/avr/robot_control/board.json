{
  // boardName / displayName are overridden by boards.txt entry:
  //   robotControl.name=Arduino Robot Control
  "boardName": "robotControl",
  "displayName": "Arduino Robot Control",

  // ATmega32U4 at 16 MHz — the control board of the Arduino Robot kit.
  // Serial1 (D0/D1) is normally wired to the Motor board via the
  // 10-pin inter-board connector; no dedicated external serial header.
  // Serial is USB-CDC for programming only.
  // Note: this header omits NUM_DIGITAL_PINS and NUM_ANALOG_INPUTS —
  // the build script derives them from the PIN_A0 / PIN_A<n> pattern.
  "family": "avr",

  "defaultBaud": 115200,
  "supportedBauds": [
    300, 600, 1200, 2400, 4800, 9600, 14400, 19200,
    28800, 38400, 57600, 115200
  ],

  "pwm": { "min": 0, "max": 255, "method": "analogWrite" },
  "dac": {},
  // ADC: ATmega32U4 has a 10-bit ADC (0–1023).  Default reference is
  // AVCC = 5 V.  Internal 2.56 V reference available via analogReference(INTERNAL).
  "adc": { "bits": 10, "max": 1023, "defaultRefVolts": "5.0" },
  "inputOnlyGpios": [],

  // Serial1 is the accessible hardware USART on D0/D1.
  "connections": ["serial"],

  "pinNotes": {},
  "chipGpios": {}
}
