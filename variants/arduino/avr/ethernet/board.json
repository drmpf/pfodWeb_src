{
  // boardName / displayName are overridden by boards.txt entry:
  //   ethernet.name=Arduino Ethernet
  "boardName": "ethernet",
  "displayName": "Arduino Ethernet",

  // ATmega328P — same AVR header layout as the Uno.
  "family": "avr",

  "defaultBaud": 115200,
  "supportedBauds": [
    300, 600, 1200, 2400, 4800, 9600, 14400, 19200,
    28800, 38400, 57600, 115200
  ],

  "pwm": { "min": 0, "max": 255, "method": "analogWrite" },
  "dac": {},
  // ADC: ATmega328P has a 10-bit ADC (0–1023).  Default reference is
  // AVCC = 5 V.  Internal 1.1 V reference available via analogReference(INTERNAL).
  "adc": { "bits": 10, "max": 1023, "defaultRefVolts": "5.0" },
  "inputOnlyGpios": [],

  // Hardware UART on D0/D1 for direct serial connection.
  // Built-in W5100 Ethernet jack supports pfod over TCP.
  "connections": ["serial", "tcp"],

  "pinNotes": {},
  "chipGpios": {}
}
